FRONTEND_URL=http://localhost:5173
DATABASE_URL=
TRIGGER_SECRET_KEY=
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
OPENAI_API_KEY=
# Optional: defaults to gpt-4o-mini (leave unset or blank to use default)
OPENAI_RESEARCH_MODEL=
# Apify — required for live actor runs (otherwise agents return empty datasets)
APIFY_API_TOKEN=
# CourtListener — token from https://www.courtlistener.com/ profile (API v4 docket detail requires auth).
# Must also be set in Trigger.dev → Project → Environment variables for deployed runs (not only local .env).
COURTLISTENER_API_TOKEN=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
